{
  "name": "@turbomem/cli",
  "version": "0.5.9",
  "description": "Command-line interface for turbomem (local-first agent memory). Add, search, and manage memories from your terminal.",
  "homepage": "https://docs.turbomem.dev",
  "license": "Apache-2.0",
  "author": "arneesh aima",
  "repository": {
    "type": "git",
    "url": "https://github.com/turbomem/turbomem.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "turbomem",
    "memory",
    "agent",
    "cli",
    "ai",
    "llm"
  ],
  "type": "module",
  "bin": {
